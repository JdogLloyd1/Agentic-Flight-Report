# Ollama Cloud
OLLAMA_API_KEY=
OLLAMA_MODEL=qwen3.5:397b
# Chat sampling: 0 improves repeatability; default also in app/rag/settings.py
OLLAMA_TEMPERATURE=0

# MCP tool server — on Connect, set to the public base URL of the deployed HTTP bridge (no trailing slash).
# Leave empty to run tools in-process in the Shiny worker (simplest; heavier on the Shiny container).
MCP_BASE_URL=

# TSA wait times: legacy DHS MyTSA JSON often redirects. Set to a URL that returns JSON for an airport
# (use placeholders {airport_code} or {code}), e.g. your internal bridge to a supported vendor API.
TSA_WAIT_TIMES_PROXY_URL=

# RAG document directory (optional — defaults to app/rag/data under the app package)
RAG_DATA_DIR=

# OpenSky Network (optional — anonymous access works without these but with tighter rate limits)
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# --- rsconnect CLI (used only on the machine that runs scripts/deploy_*.py; also set these in Connect UI for runtime secrets) ---
# Base URL of your Posit Connect server, e.g. https://connect.example.com/
CONNECT_SERVER=
# API key (same as Posit “publisher” key). Aliases: POSIT_CONNECT_PUBLISHER, CONNECT_API_KEY
POSIT_CONNECT_PUBLISHER=
# CONNECT_API_KEY=

# Python version available on Connect build image (see build logs)
CONNECT_PYTHON_VERSION=3.12.4

# Shiny content GUID from Connect (…/content/<guid>/) — redeploy in place via scripts/deploy_shiny.py
CONNECT_SHINY_APP_ID=
