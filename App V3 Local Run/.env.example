# Ollama Cloud
OLLAMA_API_KEY=
OLLAMA_MODEL=qwen3.5:397b
# Chat sampling: 0 improves repeatability; default also in app/rag/settings.py
OLLAMA_TEMPERATURE=0

# MCP tool server (optional — leave unset to call tools in-process from mcp_server.tools)
MCP_BASE_URL=

# TSA wait times: legacy DHS MyTSA JSON often redirects. Set to a URL that returns JSON for an airport
# (use placeholders {airport_code} or {code}), e.g. your internal bridge to a supported vendor API.
TSA_WAIT_TIMES_PROXY_URL=

# RAG document directory (optional — defaults to app/rag/data under the app package)
RAG_DATA_DIR=

# OpenSky Network (optional — anonymous access works without these but with tighter rate limits)
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=
